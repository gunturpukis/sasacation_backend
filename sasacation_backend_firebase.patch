diff --git a/.env.example b/.env.example
index c7b88e9..fa07b5c 100644
--- a/.env.example
+++ b/.env.example
@@ -1,3 +1,28 @@
+# ── Server ────────────────────────────────────────────────────────────────
+PORT=5001
+NODE_ENV=development
+
+# ── Database (WAJIB) ─────────────────────────────────────────────────────
+# Contoh untuk DBngin/PostgreSQL lokal:
+DATABASE_URL=postgresql://postgres@localhost:5432/sasacation
+
+# ── JWT (WAJIB) ───────────────────────────────────────────────────────────
 JWT_SECRET=supersecret123
+JWT_EXPIRES_IN=7d
+
+# ── Ollama (AI & RAG) ─────────────────────────────────────────────────────
 OLLAMA_BASE_URL=http://localhost:11434
-OLLAMA_MODEL=qwen2.5:7brs
\ No newline at end of file
+OLLAMA_MODEL=llama3.1:latest
+OLLAMA_EMBED_MODEL=nomic-embed-text
+
+# ── Firebase Admin SDK (Auth + Push Notification) ───────────────────────
+# Ambil dari Firebase Console -> Project Settings -> Service Accounts ->
+# Generate New Private Key. Simpan file JSON-nya di luar folder yang
+# ter-commit ke git, lalu isi salah satu opsi di bawah:
+#
+# Opsi A (disarankan untuk lokal): path ke file JSON
+FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
+#
+# Opsi B (disarankan untuk deployment/CI): isi JSON credential langsung
+# sebagai satu baris string (escape newline di private_key dengan \n)
+# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...", ...}
